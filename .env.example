# Pick one network and keep every value below consistent with it.
# Mixing devnet/mainnet values across these fields is the most common
# activation failure.

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# If your folder is `tx-on-chain-main`, use the path below.
# If you cloned into `reference/tx-on-chain`, set that path instead.
TXLINE_IDL_PATH=tx-on-chain-main/idl/txoracle.json
WALLET_KEYPAIR_PATH=./wallet-devnet.json

# --- mainnet equivalents, for later ---
